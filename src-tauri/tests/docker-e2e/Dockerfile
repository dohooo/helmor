# End-to-end test image for the remote-runner SSH transport.
#
# Two stages:
#   1. `builder` — a native `rust` image compiles `helmor-server`
#      for the image's own architecture. Building natively (arm64
#      builder on Apple Silicon, amd64 builder on GitHub runners)
#      sidesteps the cross-toolchain mismatch `cross` hits with the
#      repo's pinned `rust-toolchain.toml` under QEMU.
#   2. runtime — `debian:bookworm-slim` + sshd + the freshly-built
#      daemon at `$HOME/.helmor/server/helmor-server`. Stands in for
#      a remote host the desktop SSHes into.
#
# IMPORTANT: the `src-tauri` crate links the GUI `tauri` crate even
# for the headless `helmor-server` binary (Tauri's plugin/command
# registration uses link-time static registration the linker can't
# dead-strip), so the daemon binary has `libwebkit2gtk` / `libgtk-3`
# in its runtime NEEDED set. It never opens a window (never calls
# `run()` / `gtk_init`), so it runs fine headless — but the libs
# must be *present* at exec time. The runtime stage therefore
# installs the GTK/webkit RUNTIME libraries (the `-0` packages, not
# `-dev`). A real remote host has the same prerequisite; see
# `install.rs` + the user guide.
#
# Build context is the REPO ROOT (see compose.yml build.context):
# the build needs `src-tauri/` AND the frontend file
# `src/shared/builtin-claude-providers.json` that `helmor_lib`
# pulls via `include_str!`. The `Dockerfile.dockerignore` keeps the
# heavy dirs (target/, node_modules/, .git/, dist/) out of the
# context transfer.

# ── Stage 1: build helmor-server natively ──────────────────────────
FROM rust:1.94-bookworm AS builder

# Tauri v2 Linux build deps — needed at LINK time even for the
# headless binary.
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        libwebkit2gtk-4.1-dev \
        libgtk-3-dev \
        libayatana-appindicator3-dev \
        librsvg2-dev \
        libsoup-3.0-dev \
        libjavascriptcoregtk-4.1-dev \
        pkg-config \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /repo

# sccache isn't in the image; the repo's .cargo/config.toml sets
# `rustc-wrapper = "sccache"`, so disable it for the container build.
ENV RUSTC_WRAPPER=""
ENV CARGO_TARGET_DIR=/build-target

# Copy the repo (Dockerfile.dockerignore trims the heavy dirs).
COPY . .

# `tauri-build` validates `tauri.conf.json` resources; the
# `vendor/` dir is gitignored (normally generated by the sidecar
# build), so create an empty placeholder to satisfy validation —
# the headless daemon doesn't use bundled resources.
RUN mkdir -p sidecar/dist/vendor

# Debug build: the lib's `crate-type = [staticlib, cdylib, rlib]`
# makes a release build of the daemon OOM at opt-level 3 (cdylib +
# LLVM whole-program). The E2E only needs a *functioning* binary,
# so debug is the right trade — far less memory, faster, identical
# wire behaviour.
RUN cd src-tauri \
    && cargo build --bin helmor-server \
    && cp /build-target/debug/helmor-server /helmor-server

# ── Stage 2: sshd runtime ──────────────────────────────────────────
FROM debian:bookworm-slim

# openssh-server + the daemon's GUI runtime libs (loaded at exec,
# never used) + the install-script tools (curl/sha256sum/tar/git).
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        openssh-server \
        libwebkit2gtk-4.1-0 \
        libgtk-3-0 \
        libayatana-appindicator3-1 \
        librsvg2-2 \
        libsoup-3.0-0 \
        curl \
        ca-certificates \
        tar \
        coreutils \
        git \
        procps \
        iproute2 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && mkdir -p /var/run/sshd

# Deterministic sshd: key-only auth (matches the desktop's
# BatchMode=yes), no root login.
RUN sed -i \
        -e 's|#PasswordAuthentication yes|PasswordAuthentication no|' \
        -e 's|#PermitRootLogin prohibit-password|PermitRootLogin no|' \
        -e 's|#PermitUserEnvironment no|PermitUserEnvironment yes|' \
        /etc/ssh/sshd_config

# Test user + managed daemon dir. The host-side test writes its
# public key into /home/e2e/.ssh/authorized_keys via a read-only
# bind mount at compose time.
RUN useradd --create-home --shell /bin/bash --uid 1000 e2e \
    && mkdir -p /home/e2e/.ssh /home/e2e/.helmor/server \
    && chmod 700 /home/e2e/.ssh \
    && chown -R e2e:e2e /home/e2e

# Bake the daemon into the managed location so the desktop's probe
# finds it immediately (the transport test connects to a ready
# daemon; the install path has its own unit coverage).
COPY --from=builder /helmor-server /home/e2e/.helmor/server/helmor-server
RUN chmod 0755 /home/e2e/.helmor/server/helmor-server \
    && chown e2e:e2e /home/e2e/.helmor/server/helmor-server

# Prove the daemon actually executes on this arch with the runtime
# libs present — fails the build here rather than at first-connect
# if a NEEDED lib is missing or the arch is wrong.
RUN /home/e2e/.helmor/server/helmor-server --version

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D", "-e"]
