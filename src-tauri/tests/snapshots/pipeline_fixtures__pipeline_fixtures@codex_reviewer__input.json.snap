      .unwrap()\n  1129\t            .flat_map(Result::ok)\n  1130\t            .map(|entry| entry.path())\n  1131\t            .collect::<Vec<_>>();\n  1132\t        log_files.sort();\n  1133\t\n  1134\t        assert!(!log_files.is_empty());\n  1135\t        let setup_log = log_files[0].join(\"setup.log\");\n  1136\t        assert!(setup_log.is_file());\n  1137\t        let setup_log_contents = fs::read_to_string(setup_log).unwrap();\n  1138\t        assert!(setup_log_contents.contains(\"failing setup\"));\n"
