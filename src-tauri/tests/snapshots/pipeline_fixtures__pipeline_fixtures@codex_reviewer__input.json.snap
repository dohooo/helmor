      result: "   720\t        let connection = Connection::open(crate::data_dir::db_path().unwrap()).unwrap();\n   721\t\n   722\t        connection\n   723\t            .execute(\n   724\t                \"UPDATE sessions SET unread_count = 1 WHERE id = ?1\",\n   725\t                [&harness.session_id],\n   726\t            )\n   727\t            .unwrap();\n   728\t        connection\n   729\t            .execute(\n   730\t                \"UPDATE workspaces SET unread = 0 WHERE id = ?1\",\n   731\t                [&harness.workspace_id],\n   732\t            )\n   733\t            .unwrap();\n   734\t\n   735\t        let record = workspaces::load_workspace_record_by_id(&harness.workspace_id)\n   736\t            .unwrap()\n   737\t            .unwrap();\n   738\t\n   739\t        assert!(record.has_unread);\n   740\t        assert_eq!(record.workspace_unread, 0);\n   741\t        assert_eq!(record.session_unread_total, 1);\n   742\t        assert_eq!(record.unread_session_count, 1);\n   743\t    }\n   744\t\n   745\t    #[test]\n   746\t    fn archived_workspace_summary_reports_unread_state() {\n   747\t        let _guard = TEST_LOCK\n   748\t            .lock()\n   749\t            .unwrap_or_else(|poisoned| poisoned.into_inner());\n   750\t        let harness = RestoreTestHarness::new(true);\n   751\t        let connection = Connection::open(crate::data_dir::db_path().unwrap()).unwrap();\n   752\t\n   753\t        connection\n   754\t            .execute(\n   755\t                \"UPDATE sessions SET unread_count = 1 WHERE id = ?1\",\n   756\t                [&harness.session_id],\n   757\t            )\n   758\t            .unwrap();\n   759\t        connection\n   760\t            .execute(\n   761\t                \"UPDATE workspaces SET unread = 0 WHERE id = ?1\",\n   762\t                [&harness.workspace_id],\n   763\t            )\n   764\t            .unwrap();\n   765\t\n   766\t        let record = workspaces::load_workspace_record_by_id(&harness.workspace_id)\n   767\t            .unwrap()\n   768\t            .unwrap();\n   769\t        let summary = workspaces::record_to_summary(record);\n   770\t\n   771\t        assert!(summary.has_unread);\n   772\t        assert_eq!(summary.session_unread_total, 1);\n   773\t        assert_eq!(summary.unread_session_count, 1);\n   774\t    }\n   775\t\n   776\t    #[test]\n   777\t    fn mark_session_read_clears_session_and_workspace_unread() {\n   778\t        let _guard = TEST_LOCK\n   779\t            .lock()\n   780\t            .unwrap_or_else(|poisoned| poisoned.into_inner());\n   781\t        let harness = ArchiveTestHarness::new(true);\n   782\t        let connection = Connection::open(crate::data_dir::db_path().unwrap()).unwrap();\n   783\t\n   784\t        connection\n   785\t            .execute(\n   786\t                \"UPDATE sessions SET unread_count = 1 WHERE id = ?1\",\n   787\t                [&harness.session_id],\n   788\t            )\n   789\t            .unwrap();\n   790\t        connection\n   791\t            .execute(\n   792\t                \"UPDATE workspaces SET unread = 1 WHERE id = ?1\",\n   793\t                [&harness.workspace_id],\n   794\t            )\n   795\t            .unwrap();\n   796\t\n   797\t        sessions::mark_session_read(&harness.session_id).unwrap();\n   798\t\n   799\t        let (session_unread, workspace_unread): (i64, i64) = connection\n   800\t            .query_row(\n   801\t                \"SELECT (SELECT unread_count FROM sessions WHERE id = ?1), (SELECT unread FROM workspaces WHERE id = ?2)\",\n   802\t                (&harness.session_id, &harness.workspace_id),\n   803\t                |row| Ok((row.get(0)?, row.get(1)?)),\n   804\t            )\n   805\t            .unwrap();\n   806\t\n   807\t        assert_eq!(session_unread, 0);\n   808\t        assert_eq!(workspace_unread, 0);\n   809\t    }\n   810\t\n   811\t    #[test]\n   812\t    fn mark_workspace_read_clears_all_workspace_sessions() {\n   813\t        let _guard = TEST_LOCK\n   814\t            .lock()\n   815\t            .unwrap_or_else(|poisoned| poisoned.into_inner());\n   816\t        let harness = ArchiveTestHarness::new(true);\n   817\t        let connection = Connection::open(crate::data_dir::db_path().unwrap()).unwrap();\n   818\t\n   819\t        connection\n   820\t            .execute(\n   821\t                \"UPDATE sessions SET unread_count = 1 WHERE id = ?1\",\n   822\t                [&harness.session_id],\n   823\t            )\n   824\t            .unwrap();\n   825\t        connection\n   826\t            .execute(\n   827\t                r#\"\n   828\t                INSERT INTO sessions (\n   829\t                  id, workspace_id, title, agent_type, status, model, permission_mode,\n   830\t                  claude_session_id, unread_count, context_token_count, context_used_percent,\n   831\t                  thinking_enabled, codex_thinking_level, fast_mode, agent_personality,\n   832\t                  created_at, updated_at, last_user_message_at, resume_session_at,\n   833\t                  is_hidden, is_compacting\n   834\t                ) VALUES ('session-archive-2', ?1, 'Second session', 'claude', 'idle', 'opus', 'default', NULL, 2, 0, NULL, 0, NULL, 0, 'none', CURRENT_TIMESTAMP, CURRENT_TIMESTAMP, NULL, NULL, 0, 0)\n   835\t                \"#,\n   836\t                [&harness.workspace_id],\n   837\t            )\n   838\t            .unwrap();\n   839\t        connection\n   840\t            .execute(\n"
