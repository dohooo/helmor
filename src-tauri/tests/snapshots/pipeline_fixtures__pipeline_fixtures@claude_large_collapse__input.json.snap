          result: "     1→package article\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"strings\"\n     7→\n     8→\thderror_code \"hdcode/common/util/enums/respcodeenum\"\n     9→\t\"hdcode/common/util/hd_string\"\n    10→\t\"hdcode/common/util/hderror\"\n    11→\t\"hdcode/hd-ai-center/ai/hd_ai_search/hd_ai_search\"\n    12→\t\"hdcode/hd-ai-center/ai/hd_ai_search/services/qa/stream_chat\"\n    13→\tthread_memory_service \"hdcode/hd-ai-center/ai/hd_ai_search/services/thread_memory\"\n    14→\t\"hdcode/hd-ai-center/ai/hd_ai_search/utils/enums/common/SESSION_TYPE\"\n    15→\t\"hdcode/hd-ai-center/ai/hd_ai_search/utils/enums/common/TASK_STEP\"\n    16→)\n    17→\n    18→func (s *Service) shouldUseArticleBootstrapPipeline(in *hd_ai_search.ImChatRequest) (bool, error) {\n    19→\tsessionType, useSessionInput, err := s.resolveArticleBootstrapSessionContext(in)\n    20→\tif err != nil {\n    21→\t\treturn false, err\n    22→\t}\n    23→\treturn useSessionInput && sessionType == int64(SESSION_TYPE.ARTICLE.Code), nil\n    24→}\n    25→\n    26→func (s *Service) executeArticleBootstrapPipeline(ctx context.Context, in *hd_ai_search.ImChatRequest, sessionID string, executionCtx *BootstrapExecutionContext, externalSender stream_chat.ExternalStreamSender) error {\n    27→\ts.Logger.Infof(\"executeArticleBootstrapPipeline begin in=%s session_id=%s\", hd_string.ObjToJsonStr(in), sessionID)\n    28→\n    29→\tarticleCtx := s.loadArticleContextForSession(sessionID)\n    30→\tif articleCtx == nil {\n    31→\t\terr := hderror.NewErrorMsg(hderror_code.FAIL, \"executeArticleBootstrapPipeline 文章上下文已失效\")\n    32→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline article_ctx_missing in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n    33→\t\treturn err\n    34→\t}\n    35→\tpayload := in.GetSessionInputPayload()\n    36→\tarticleSource, err := buildArticleSourceStepOutput(payload, articleCtx)\n    37→\tif err != nil {\n    38→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline buildArticleSourceStepOutput_failed in=%s session_id=%s payload=%s article_ctx=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, hd_string.ObjToJsonStr(payload), hd_string.ObjToJsonStr(articleCtx), err)\n    39→\t\treturn err\n    40→\t}\n    41→\n    42→\trunner, err := s.newArticleTaskRunner(\n    43→\t\tctx,\n    44→\t\tstrings.TrimSpace(in.GetUserId()),\n    45→\t\tsessionID,\n    46→\t\tarticleBootstrapTaskType,\n    47→\t\twithArticleTaskReuseExistingTask(),\n    48→\t\twithArticleTaskReuseStepByIdentifier(),\n    49→\t)\n    50→\tif err != nil {\n    51→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline newArticleTaskRunner_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n    52→\t\treturn err\n    53→\t}\n    54→\n    55→\tsourceRaw, err := runner.executeStep(articleStepSourceIdentifier, \"文章原文\", TASK_STEP.READING.Code, func() (string, error) {\n    56→\t\traw, marshalErr := json.Marshal(articleSource)\n    57→\t\tif marshalErr != nil {\n    58→\t\t\treturn \"\", marshalErr\n    59→\t\t}\n    60→\t\treturn string(raw), nil\n    61→\t})\n    62→\tif err != nil {\n    63→\t\t_ = runner.failTask()\n    64→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline execute_source_failed in=%s session_id=%s article_source=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, hd_string.ObjToJsonStr(articleSource), err)\n    65→\t\treturn err\n    66→\t}\n    67→\tvar persistedArticleSource articleSourceStepOutput\n    68→\tif err = json.Unmarshal([]byte(strings.TrimSpace(sourceRaw)), &persistedArticleSource); err != nil {\n    69→\t\t_ = runner.failTask()\n    70→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline unmarshal_source_failed in=%s session_id=%s raw=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, strings.TrimSpace(sourceRaw), err)\n    71→\t\treturn err\n    72→\t}\n    73→\n    74→\ta01Raw, err := runner.executeStep(articleStepA01Identifier, \"文章关联判断\", TASK_STEP.READING.Code, func() (string, error) {\n    75→\t\tout, runErr := s.runArticleA01Step(ctx, strings.TrimSpace(in.GetUserId()), sessionID, &persistedArticleSource)\n    76→\t\tif runErr != nil {\n    77→\t\t\treturn \"\", runErr\n    78→\t\t}\n    79→\t\traw, marshalErr := json.Marshal(out)\n    80→\t\tif marshalErr != nil {\n    81→\t\t\treturn \"\", marshalErr\n    82→\t\t}\n    83→\t\treturn string(raw), nil\n    84→\t})\n    85→\tif err != nil {\n    86→\t\t_ = runner.failTask()\n    87→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline execute_a01_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n    88→\t\treturn err\n    89→\t}\n    90→\n    91→\tvar a01Out articleA01StepOutput\n    92→\tif err = json.Unmarshal([]byte(strings.TrimSpace(a01Raw)), &a01Out); err != nil {\n    93→\t\t_ = runner.failTask()\n    94→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline unmarshal_a01_failed in=%s session_id=%s raw=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, strings.TrimSpace(a01Raw), err)\n    95→\t\treturn err\n    96→\t}\n    97→\n    98→\tif err = s.closeExternalSender(externalSender); err != nil {\n    99→\t\t_ = runner.failTask()\n   100→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline closeExternalSender_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n   101→\t\treturn err\n   102→\t}\n   103→\n   104→\ts.Logger.Infof(\"executeArticleBootstrapPipeline persist_main_session_card_begin session_id=%s task_id=%d step_id=%d\", sessionID, runner.task.TaskId, runner.task.CurrentStepId)\n   105→\tif err = persistArticleMainSessionCardContext(s.Logger, s.svcCtx.MemoryRedis, sessionID, a01Out); err != nil {\n   106→\t\t_ = runner.failTask()\n   107→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline persistArticleMainSessionCardContext_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n   108→\t\treturn err\n   109→\t}\n   110→\ts.Logger.Infof(\"executeArticleBootstrapPipeline persist_main_session_card_success session_id=%s task_id=%d step_id=%d\", sessionID, runner.task.TaskId, runner.task.CurrentStepId)\n   111→\n   112→\timClient, err := s.getIMClient()\n   113→\tif err != nil {\n   114→\t\t_ = runner.failTask()\n   115→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline getIMClient_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n   116→\t\treturn err\n   117→\t}\n   118→\tmainSessionID := \"\"\n   119→\ttaskCtx, taskCtxErr := getImSubSessionTaskContext(s.svcCtx.MemoryRedis, sessionID)\n   120→\tif taskCtxErr != nil {\n   121→\t\ts.Logger.Infof(\"executeArticleBootstrapPipeline load_task_context_for_log_failed session_id=%s err=%v\", sessionID, taskCtxErr)\n   122→\t} else if taskCtx != nil {\n   123→\t\tmainSessionID = strings.TrimSpace(taskCtx.MainSessionID)\n   124→\t}\n   125→\n   126→\tresultCard := buildArticleResultCard(&persistedArticleSource, a01Out, runner.task.TaskId, runner.task.CurrentStepId)\n   127→\ts.Logger.Infof(\"executeArticleBootstrapPipeline send_result_card_begin session_id=%s main_session_id=%s task_id=%d step_id=%d result_msg_type=%s\", sessionID, mainSessionID, runner.task.TaskId, runner.task.CurrentStepId, articlePayloadMsgType(resultCard))\n   128→\ta01MsgSeq, err := sendArticleCustomMessageWithResult(ctx, s.Logger, imClient, sessionID, resultCard)\n   129→\tif err != nil {\n   130→\t\t_ = runner.failTask()\n   131→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline send_result_card_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n   132→\t\treturn err\n   133→\t}\n   134→\ts.Logger.Infof(\"executeArticleBootstrapPipeline send_result_card_success session_id=%s main_session_id=%s task_id=%d step_id=%d result_msg_type=%s result_msg_seq=%d\", sessionID, mainSessionID, runner.task.TaskId, runner.task.CurrentStepId, articlePayloadMsgType(resultCard), a01MsgSeq)\n   135→\n   136→\tstate := &articleUIState{\n   137→\t\tSessionID:      sessionID,\n   138→\t\tCurrentMode:    \"\",\n   139→\t\tA01MessageSeq:  a01MsgSeq,\n   140→\t\tModeMessageSeq: 0,\n   141→\t}\n   142→\ts.Logger.Infof(\"executeArticleBootstrapPipeline save_ui_state_begin session_id=%s current_mode=%s a01_msg_seq=%d mode_card_msg_seq=%d decision_msg_seq=%d\", sessionID, state.CurrentMode, state.A01MessageSeq, state.ModeMessageSeq, 0)\n   143→\tif err = saveArticleUIState(s.svcCtx.MemoryRedis, state); err != nil {\n   144→\t\t_ = runner.failTask()\n   145→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline saveArticleUIState_failed in=%s session_id=%s state=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, hd_string.ObjToJsonStr(state), err)\n   146→\t\treturn err\n   147→\t}\n   148→\ts.Logger.Infof(\"executeArticleBootstrapPipeline save_ui_state_success session_id=%s current_mode=%s a01_msg_seq=%d mode_card_msg_seq=%d decision_msg_seq=%d\", sessionID, state.CurrentMode, state.A01MessageSeq, state.ModeMessageSeq, 0)\n   149→\n   150→\tif executionCtx != nil && executionCtx.PersistQA != nil {\n   151→\t\tupdateErr := s.updateArticleBootstrapPersistQA(executionCtx.PersistQA, a01Out)\n   152→\t\tif updateErr != nil {\n   153→\t\t\t_ = runner.failTask()\n   154→\t\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline updateArticleBootstrapPersistQA_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, updateErr)\n   155→\t\t\treturn updateErr\n   156→\t\t}\n   157→\t}\n   158→\n   159→\tif err = runner.completeTask(); err != nil {\n   160→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline completeTask_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, err)\n   161→\t\treturn err\n   162→\t}\n   163→\trecordErr := thread_memory_service.RecordThreadCreationMemory(ctx, s.svcCtx, s.Logger, buildArticleThreadCreationMemoryData(sessionID, articleCtx, &persistedArticleSource, &a01Out))\n   164→\tif recordErr != nil {\n   165→\t\ts.Logger.Errorf(\"executeArticleBootstrapPipeline RecordThreadCreationMemory_failed in=%s session_id=%s err=%v\", hd_string.ObjToJsonStr(in), sessionID, recordErr)\n   166→\t}\n   167→\ts.Logger.Infof(\"executeArticleBootstrapPipeline bootstrap_done session_id=%s main_session_id=%s task_id=%d a01_msg_seq=%d current_mode=%s mode_card_msg_seq=%d decision_msg_seq=%d\", sessionID, mainSessionID, runner.task.TaskId, state.A01MessageSeq, state.CurrentMode, state.ModeMessageSeq, 0)\n   168→\ts.Logger.Infof(\"executeArticleBootstrapPipeline success in=%s session_id=%s task_id=%d\", hd_string.ObjToJsonStr(in), sessionID, runner.task.TaskId)\n   169→\treturn nil\n   170→}\n   171→"
