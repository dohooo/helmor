Client, err := sdk_hddi_boss_bot.GetClient()\n    65→\tif err != nil {\n    66→\t\ts.Logger.Errorf(\"getIMClient GetClient_failed err=%v\", err)\n    67→\t\treturn nil, err\n    68→\t}\n    69→\tif imClient == nil {\n    70→\t\terr = hderror.NewErrorMsg(hderror_code.FAIL, \"getIMClient Tencent IMnotstartuse\")\n    71→\t\ts.Logger.Errorf(\"getIMClient client_nil err=%v\", err)\n    72→\t\treturn nil, err\n    73→\t}\n    74→\treturn imClient, nil\n    75→}\n    76→\n    77→func trimSessionID(sessionID string) string {\n    78→\treturn strings.TrimSpace(sessionID)\n    79→}\n    80→\n    81→func newFailError(msg string) error {\n    82→\treturn hderror.NewErrorMsg(hderror_code.FAIL, msg)\n    83→}\n    84→"
