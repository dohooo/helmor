          result: "     1→package article\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\n     6→\t\"hdcode/hd-ai-center/ai/hd_ai_search/hd_ai_search\"\n     7→\t\"hdcode/hd-ai-center/ai/hd_ai_search/internal/logic/imchat/msgtype\"\n     8→\t\"hdcode/hd-ai-center/ai/hd_ai_search/services/qa/stream_chat\"\n     9→\t\"hdcode/hd-ai-center/ai/hd_ai_search/services/qa/stream_chat/provider\"\n    10→)\n    11→\n    12→// ShouldUseArticleBootstrapPipeline determine if current request should go through article bootstrap pipeline。\n    13→func (s *Service) ShouldUseArticleBootstrapPipeline(in *hd_ai_search.ImChatRequest) (bool, error) {\n    14→\treturn s.shouldUseArticleBootstrapPipeline(in)\n    15→}\n    16→\n    17→// ExecuteBootstrapPipeline executearticle bootstrap pipeline。\n    18→func (s *Service) ExecuteBootstrapPipeline(ctx context.Context, in *hd_ai_search.ImChatRequest, sessionID string, executionCtx *BootstrapExecutionContext, externalSender stream_chat.ExternalStreamSender) error {\n    19→\treturn s.executeArticleBootstrapPipeline(ctx, in, sessionID, executionCtx, externalSender)\n    20→}\n    21→\n    22→func (s *Service) PrepareSessionContext(in *ApiProxyDispatchInput, sessionID string) (*ArticleSessionContext, error) {\n    23→\treturn s.prepareArticleSessionContext(in, sessionID)\n    24→}\n    25→\n    26→func (s *Service) SaveSessionContext(articleCtx *ArticleSessionContext) error {\n    27→\treturn saveImArticleSessionContext(s.svcCtx.MemoryRedis, articleCtx)\n    28→}\n    29→\n    30→func (s *Service) LoadSessionContext(sessionID string) *ArticleSessionContext {\n    31→\treturn s.loadArticleContextForSession(sessionID)\n    32→}\n    33→\n    34→func (s *Service) DeleteSessionContext(sessionID string) error {\n    35→\treturn deleteImArticleSessionContext(s.svcCtx.MemoryRedis, sessionID)\n    36→}\n    37→\n    38→func (s *Service) SaveUIState(state *ArticleUIState) error {\n    39→\treturn saveArticleUIState(s.svcCtx.MemoryRedis, state)\